const char *contrast_frag_src =
"uniform sampler2D tex0;\n"
"uniform vec3 u_contrastAdd;\n"
"uniform vec3 u_contrastMult;\n"
"\n"
"FSIN vec4 v_color;\n"
"FSIN vec2 v_tex0;\n"
"FSIN float v_fog;\n"
"\n"
"void\n"
"main(void)\n"
"{\n"
"\tvec4 dst = texture(tex0, vec2(v_tex0.x, 1.0-v_tex0.y));\n"
"\tvec4 color;\n"
"\tcolor.rgb = dst.rgb*u_contrastMult + u_contrastAdd;\n"
"\tcolor.a = 1.0;\n"
"\n"
"\tFRAGCOLOR(color);\n"
"}\n"
"\n"
";
