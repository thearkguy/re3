const char *im2d_vert_src =
"uniform vec4 u_xform;\n"
"\n"
"VSIN(ATTRIB_POS)\tvec4 in_pos;\n"
"\n"
"VSOUT vec4 v_color;\n"
"VSOUT vec2 v_tex0;\n"
"VSOUT float v_fog;\n"
"\n"
"void\n"
"main(void)\n"
"{\n"
"\tgl_Position = in_pos;\n"
"\tgl_Position.w = 1.0;\n"
"\tgl_Position.xy = gl_Position.xy * u_xform.xy + u_xform.zw;\n"
"\tv_fog = DoFog(gl_Position.z);\n"
"\tgl_Position.xyz *= gl_Position.w;\n"
"\tv_color = in_color;\n"
"\tv_tex0 = in_tex0;\n"
"}\n"
";
