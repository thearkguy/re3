const char *simple_frag_src =
"uniform sampler2D tex0;\n"
"\n"
"FSIN vec4 v_color;\n"
"FSIN vec2 v_tex0;\n"
"FSIN float v_fog;\n"
"\n"
"void\n"
"main(void)\n"
"{\n"
"\tvec4 color;\n"
"\tcolor = v_color*texture(tex0, vec2(v_tex0.x, 1.0-v_tex0.y));\n"
"\tcolor.rgb = mix(u_fogColor.rgb, color.rgb, v_fog);\n"
"\tDoAlphaTest(color.a);\n"
"\n"
"\tFRAGCOLOR(color);\n"
"}\n"
"\n"
";
